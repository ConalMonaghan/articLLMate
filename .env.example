# Copy this file to .env and fill in your values
# .env is git-ignored and will never be committed

# Required: at least one API key for your chosen provider
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GEMINI_API_KEY=your-gemini-key-here

# Elsevier API (only needed for PDF XML pipeline/0. Elsevier API)
# ELSEVIER_API_KEY=your-elsevier-key-here

# Crossref polite pool email (used by pipeline scripts for metadata lookups)
# CROSSREF_EMAIL=your.email@example.com

# Google Sheets monitoring dashboard (only needed if dashboard = TRUE)
# GSHEET_MONITOR_ID=your-google-sheet-id-here
