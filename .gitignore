# API keys and secrets - never commit these
.env

# R session files
.Rhistory
.RData
.Rproj.user/

# Python
__pycache__/
*.pyc

# OS junk
.DS_Store
Thumbs.db

# R data files
*.rds

# Output data (regenerated per run)
output/

# Large input corpora (users supply their own)
input/pilot_sample/
input/R test/

# Service account keys
keys/

# Installers / large binaries
Miniforge*

# Generated files
*.html

# Databases
*.sqlite
*.db

# Logs
*.log

# Deployment config (contains account-specific details)
.posit/

# Temp / scratch
temp/
