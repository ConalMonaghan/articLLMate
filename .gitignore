# API keys and secrets - never commit these
.env

# R session files
.Rhistory
.RData
.Rproj.user/

# Python
__pycache__/
*.pyc

# OS junk
.DS_Store
Thumbs.db

# R data files
*.rds

# Output data (regenerated per run)
output/

# Input corpora — copyrighted article full-text; users supply their own.
# Ignore the whole tree so numbered stage folders (01_, 02_, ...) never go live.
input/

# Project-specific built prompts (embed article-derived text). Keep the public
# top-level template ("prompts/Prompt Template"); ignore per-project subfolders.
prompts/*/

# Service account keys
keys/

# Installers / large binaries
Miniforge*

# Generated files
*.html

# Databases
*.sqlite
*.db

# Logs
*.log

# Deployment config (contains account-specific details)
.posit/

# Temp / scratch
temp/
